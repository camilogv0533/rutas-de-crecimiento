---
import Base from '../layouts/Base.astro';
---
<Base title="Página no encontrada" description="Esta ruta no existe — pero hay muchas otras que sí.">
<section class="skills-hero container" style="text-align: center; padding: 6rem 0;">
  <p style="font-family: 'IBM Plex Mono', monospace; color: var(--text-muted); margin-bottom: 0.5rem;">404</p>
  <h1>Esta ruta no existe.</h1>
  <p class="lede">Pero hay muchas otras que sí llevan a algún lado.</p>
  <div class="home-hero__actions" style="justify-content: center; margin-top: 2rem;">
    <a href="/retiros" class="btn-primary">Ver retiros</a>
    <a href="/buscar" class="btn-ghost">Buscar</a>
  </div>
</section>
</Base>
