---
import Base from '../layouts/Base.astro';
import RetreatCard from '../components/RetreatCard.astro';
import { getCollection } from 'astro:content';

const retreats = await getCollection('retreats');
const skills = await getCollection('skills');
const destinations = await getCollection('destinations');

const sorted = retreats.sort((a, b) => (b.data.reviewed_by_us ? 1 : 0) - (a.data.reviewed_by_us ? 1 : 0));

const allSkillsInUse = new Set<string>();
retreats.forEach(r => r.data.skills.forEach(s => allSkillsInUse.add(s)));
const skillsWithRetreats = skills.filter(s => allSkillsInUse.has(s.data.slug));
const featuredSkills = skillsWithRetreats.slice(0, 10);

const masterminds = sorted.filter(r => (r.data.categories || []).includes('mastermind'));
const regularRetreats = sorted.filter(r => !(r.data.categories || []).includes('mastermind'));
---
<Base
  title="Rutas de Crecimiento"
  description="Directorio curado de viajes que desarrollan habilidades. Liderazgo, creatividad, propósito — un lugar, una habilidad, un viaje intencional."
>

<section class="home-hero">
  <div class="home-hero__overlay"></div>
  <div class="home-hero__split container">
    <div class="home-hero__content">
      <p class="home-hero__eyebrow">Turismo intencional</p>
      <h1 class="home-hero__headline">Viajes que desarrollan<br/>habilidades reales.</h1>
      <p class="home-hero__sub">Retiros curados donde el lugar enseña. Liderazgo en los Andes, creatividad en Oaxaca, propósito en el Mediterráneo.</p>
      <div class="home-hero__actions">
        <a href="#retiros" class="btn-primary">Ver retiros</a>
        <a href="/habilidades" class="btn-ghost">Explorar habilidades</a>
      </div>
      <div class="home-hero__stats">
        <div class="home-hero__stat"><strong>{retreats.length}</strong><span>retiros</span></div>
        <div class="home-hero__stat"><strong>{destinations.length}</strong><span>destinos</span></div>
        <div class="home-hero__stat"><strong>{skillsWithRetreats.length}</strong><span>habilidades</span></div>
      </div>
    </div>
    <div class="home-hero__visual">
      <img
        src="/img/hero.webp"
        alt="Aprendizaje en destino — Rutas de Crecimiento"
        class="home-hero__img"
        loading="eager"
        onerror="this.style.display='none'"
      />
    </div>
  </div>
</section>

<section class="skills-strip">
  <div class="container">
    <div class="skills-strip__pills">
      {featuredSkills.map(s => (
        <a href={`/habilidades/${s.data.slug}`} class="skill-chip">{s.data.name_es}</a>
      ))}
    </div>
  </div>
</section>

<section id="retiros" class="container section-lg">
  <div class="section-header">
    <h2>Retiros curados</h2>
    <a href="/retiros" class="section-link">Ver todos →</a>
  </div>
  <div class="retreat-grid">
    {regularRetreats.map((r, i) => <RetreatCard data={{ ...r.data }} index={i} />)}
  </div>
</section>

{masterminds.length > 0 && (
  <section id="masterminds" class="masterminds-section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Masterminds <span class="masterminds-badge">Grupo élite</span></h2>
          <p class="masterminds-sub">Grupos reducidos de pares que se reúnen en destino. Alta intensidad, alto impacto.</p>
        </div>
      </div>
      <div class="retreat-grid">
        {masterminds.map((r, i) => <RetreatCard data={{ ...r.data }} index={i} />)}
      </div>
    </div>
  </section>
)}

<section class="destinations-section">
  <div class="container">
    <div class="section-header">
      <h2>Destinos</h2>
      <a href="/destinos" class="section-link">Ver todos →</a>
    </div>
    <div class="destinations-grid">
      {destinations.slice(0, 6).map((d, i) => (
        <a href={`/destinos/${d.data.slug}`} class="destination-card">
          <div class="destination-card__bg" style={`background: linear-gradient(160deg, hsl(${(i * 47 + 140) % 360}, 40%, 25%) 0%, hsl(${(i * 47 + 160) % 360}, 50%, 35%) 100%)`}></div>
          {d.data.image_url && (
            <img src={d.data.image_url} alt={d.data.name} class="destination-card__photo" loading="lazy" />
          )}
          <div class="destination-card__content">
            <h3>{d.data.name}</h3>
            {d.data.narrative_hook && <p>{d.data.narrative_hook}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</Base>
