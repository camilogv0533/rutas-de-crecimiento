---
import Base from '../../layouts/Base.astro';
import RetreatCard from '../../components/RetreatCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const retreats = await getCollection('retreats');
  return retreats.map(r => ({ params: { slug: r.data.slug }, props: { entry: r } }));
}

const { entry } = Astro.props;
const r = entry.data;
const { Content } = await render(entry);

// Próxima fecha solo si es futura (datos del scrape pueden quedar viejos)
const today = new Date().toISOString().slice(0, 10);
const nextDate = r.next_date && r.next_date >= today ? r.next_date : null;
const nextDateLabel = nextDate
  ? new Date(nextDate + 'T12:00:00').toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

// Retiros relacionados: más skills compartidas, mismo país desempata
const all = await getCollection('retreats');
const related = all
  .filter(o => o.data.slug !== r.slug)
  .map(o => ({
    entry: o,
    shared: o.data.skills.filter((s: string) => r.skills.includes(s)).length,
    sameCountry: o.data.location_country && o.data.location_country === r.location_country ? 1 : 0,
  }))
  .filter(x => x.shared > 0 || x.sameCountry > 0)
  .sort((a, b) => (b.shared - a.shared) || (b.sameCountry - a.sameCountry))
  .slice(0, 3);

const schema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: r.title,
  description: r.tagline || r.what_unique,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  touristType: r.who_for,
  provider: { '@type': 'Organization', name: r.host_name, url: r.host_url }
};
if (r.price_usd_from) {
  schema.offers = { '@type': 'Offer', price: r.price_usd_from, priceCurrency: 'USD', url: r.source_url };
  if (nextDate) schema.offers.validFrom = nextDate;
}
if (r.location_city) {
  schema.location = {
    '@type': 'Place',
    name: `${r.location_city}, ${r.location_country}`,
    address: { '@type': 'PostalAddress', addressLocality: r.location_city, addressCountry: r.location_country }
  };
}
if (r.sample_itinerary) schema.itinerary = { '@type': 'ItemList', description: r.sample_itinerary };

const faqSchema = r.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: r.faq.map((f: { q: string; a: string }) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Retiros', item: new URL('/retiros', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: r.title, item: new URL(Astro.url.pathname, Astro.site).toString() },
  ],
};
---
<Base title={r.title} description={r.tagline} schema={schema} image={r.image_urls[0]}>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
<article class="narrow retreat-detail" style="padding-top: 3rem;">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="/retiros">Retiros</a> <span aria-hidden="true">›</span> <span>{r.title}</span>
  </nav>
  <h1>{r.title}</h1>
  {r.tagline && <p class="lede">{r.tagline}</p>}

  <div class="meta-bar">
    {r.location_city && <span><strong>Dónde:</strong>{r.location_city}, {r.location_country}</span>}
    {r.duration_days && <span><strong>Duración:</strong>{r.duration_days} días</span>}
    {nextDateLabel && <span><strong>Próxima fecha:</strong>{nextDateLabel}</span>}
    {r.recurring && <span><strong>Frecuencia:</strong>{r.recurring}</span>}
    {r.price_usd_from && <span class="price"><strong>Desde:</strong>${r.price_usd_from} USD</span>}
    {r.language && <span><strong>Idioma:</strong>{r.language}</span>}
    {r.group_size_max && <span><strong>Grupo máx:</strong>{r.group_size_max}</span>}
  </div>

  <a href={r.source_url} class="cta" rel="noopener nofollow" target="_blank">Ver retiro en sitio del host →</a>

  {r.what_unique && (
    <section>
      <h2>Qué lo hace único</h2>
      <p>{r.what_unique}</p>
    </section>
  )}

  {r.who_for && (
    <section>
      <h2>Para quién</h2>
      <p>{r.who_for}</p>
    </section>
  )}

  {r.skills.length > 0 && (
    <section>
      <h2>Habilidades que desarrolla</h2>
      <div>
        {r.skills.map((s: string) => (
          <a href={`/habilidades/${s}`} class="tag skill">{s.replace(/-/g, ' ')}</a>
        ))}
      </div>
    </section>
  )}

  {r.what_youll_learn && (
    <section>
      <h2>Qué aprenderás</h2>
      <p>{r.what_youll_learn}</p>
    </section>
  )}

  {r.sample_itinerary && (
    <section>
      <h2>Itinerario de ejemplo</h2>
      <p>{r.sample_itinerary}</p>
    </section>
  )}

  {(r.included || r.not_included) && (
    <section>
      <h2>Qué incluye</h2>
      {r.included && <p>{r.included}</p>}
      {r.not_included && <p><strong>No incluye:</strong> {r.not_included}</p>}
    </section>
  )}

  {(r.accommodation || r.food) && (
    <section>
      <h2>Alojamiento y comida</h2>
      {r.accommodation && <p>{r.accommodation}</p>}
      {r.food && <p>{r.food}</p>}
    </section>
  )}

  {r.faq.length > 0 && (
    <section>
      <h2>Preguntas frecuentes</h2>
      {r.faq.map((f: { q: string; a: string }) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>
  )}

  <section>
    <Content />
  </section>

  {r.host_name && (
    <section>
      <h2>Meet the host</h2>
      <p>
        <strong>{r.host_name}</strong>
        {r.host_url && <> · <a href={r.host_url} rel="noopener nofollow" target="_blank">{r.host_url}</a></>}
      </p>
    </section>
  )}

  <p style="margin-top: 3rem; color: var(--text-muted); font-size: 0.85rem;">
    Información curada por Rutas de Crecimiento. Datos del host pueden cambiar — verifica en su sitio antes de reservar.
  </p>
</article>

{related.length > 0 && (
  <section class="container section-lg">
    <div class="section-header">
      <h2>Retiros relacionados</h2>
    </div>
    <div class="retreat-grid">
      {related.map((x, i) => <RetreatCard data={{ ...x.entry.data }} index={i} />)}
    </div>
  </section>
)}
</Base>
